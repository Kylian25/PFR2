        "z": "b9abb7620754b685",
        "name": "function 1",
        "func": "// 1. Récupération de l'historique (stocké localement dans le nœud)\nlet logHistory = context.get('logHistory') || [];\n\nlet newEntry = `${msg.payload}`;\n\nlogHistory.unshift(newEntry);\n\nif (logHistory.length > 30) {\n    logHistory.pop();\n}\n\ncontext.set('logHistory', logHistory);\n\nmsg.payload = \"<pre style='margin:0; background:none; border:none; color:inherit;'>\" + logHistory.join(\"\\n\") + \"</pre>\";\n\nreturn msg;",
