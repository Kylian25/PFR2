    {
        "id": "e28aa6989f19a36d",
        "type": "function",
        "z": "b9abb7620754b685",
        "name": "format logs",
        "func": "\n// 1. Récupération de l'historique\nlet logHistory = context.get('logHistory') || [];\n\n// 2. Sécurisation de l'entrée : on s'assure que c'est du texte \n// et on coupe si c'est trop long (ex: max 1000 caractères par ligne)\nlet rawEntry = String(msg.payload);\nlet cleanEntry = rawEntry.length > 1000 ? rawEntry.substring(0, 1000) + \"...\" : rawEntry;\n\n// 3. Ajout à l'historique\nlogHistory.unshift(cleanEntry);\n\n// 4. Limitation stricte\nif (logHistory.length > 30) {\n    logHistory.pop();\n}\n\n// 5. Sauvegarde\ncontext.set('logHistory', logHistory);\n\n// 6. Construction du message (plus efficace)\nmsg.payload = `<pre style='margin:0; font-size:12px; color:inherit;'>${logHistory.join(\"\\n\")}</pre>`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
